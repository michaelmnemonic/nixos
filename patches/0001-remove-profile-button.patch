From: Remove profile button from toolbar
Subject: [PATCH] Hide the AvatarToolbarButton in the browser toolbar

Removes the profile/avatar button from the titlebar toolbar by forcing
it invisible during ToolbarView::Init(). The button object is still
constructed (to keep references that do not null-check, e.g. the glic
layout code) but is never shown.
---
 chrome/browser/ui/views/toolbar/toolbar_view.cc | 18 ++----------------
 1 file changed, 2 insertions(+), 16 deletions(-)

diff --git a/chrome/browser/ui/views/toolbar/toolbar_view.cc b/chrome/browser/ui/views/toolbar/toolbar_view.cc
--- a/chrome/browser/ui/views/toolbar/toolbar_view.cc
+++ b/chrome/browser/ui/views/toolbar/toolbar_view.cc
@@ -588,22 +588,8 @@
   if (!features::IsWebUIAvatarButtonEnabled()) {
     avatar_ =
         AddChildView(std::make_unique<AvatarToolbarButton>(browser_view_));
-    bool show_avatar_toolbar_button = true;
-#if BUILDFLAG(IS_CHROMEOS)
-    // ChromeOS only badges Incognito, Guest, and captive portal signin icons in
-    // the browser window.
-    show_avatar_toolbar_button =
-        browser_->profile()->IsIncognitoProfile() ||
-        browser_->profile()->IsGuestSession() ||
-        (browser_->profile()->IsOffTheRecord() &&
-         browser_->profile()->GetOTRProfileID().IsCaptivePortal());
-#else
-    // DevTools profiles are OffTheRecord, so hide it there.
-    show_avatar_toolbar_button = browser_->profile()->IsIncognitoProfile() ||
-                                 browser_->profile()->IsGuestSession() ||
-                                 browser_->profile()->IsRegularProfile();
-#endif
-    avatar_->SetVisible(show_avatar_toolbar_button);
+    // The profile/avatar button is intentionally hidden.
+    avatar_->SetVisible(false);
   }
 
   overflow_button_ = AddChildView(std::make_unique<OverflowButton>());
-- 
2.45.1

