index 0000000..14dfe3f
--- /dev/null
+++ b/crates/vibepanel/src/widgets/voxtype.rs
@@ -0,0 +1,175 @@
+//! VoxType widget - displays dictation state from the VoxType daemon.
+//!
+//! Shows a microphone icon that changes based on the current state:
+//! - **Idle**: dimmed mic icon
+//! - **Recording**: red/accent mic icon with `recording` CSS class
+//! - **Transcribing**: amber mic icon with `transcribing` CSS class
+//! - **Unavailable**: hidden (daemon not running)
+//!
+//! Primary click toggles recording (sends SIGUSR1/SIGUSR2 via VoxTypeService).
+
+use gtk4::GestureClick;
+use gtk4::gdk;
+use gtk4::prelude::*;
+use vibepanel_core::config::WidgetEntry;
+
+use crate::services::callbacks::CallbackId;
+use crate::services::tooltip::TooltipManager;
+use crate::services::voxtype::{VoxTypeService, VoxTypeSnapshot, VoxTypeState};
+use crate::styles::{state, widget};
+use crate::widgets::WidgetConfig;
+use crate::widgets::base::BaseWidget;
+use crate::widgets::warn_unknown_options;
+
+const DEFAULT_SHOW_ICON: bool = true;
+
+#[derive(Debug, Clone)]
+pub struct VoxTypeConfig {
+    pub show_icon: bool,
+}
+
+impl WidgetConfig for VoxTypeConfig {
+    fn from_entry(entry: &WidgetEntry) -> Self {
+        warn_unknown_options("voxtype", entry, &["show_icon"]);
+
+        let show_icon = entry
+            .options
+            .get("show_icon")
+            .and_then(|v| v.as_bool())
+            .unwrap_or(DEFAULT_SHOW_ICON);
+
+        Self { show_icon }
+    }
+}
+
+impl Default for VoxTypeConfig {
+    fn default() -> Self {
+        Self {
+            show_icon: DEFAULT_SHOW_ICON,
+        }
+    }
+}
+
+pub struct VoxTypeWidget {
+    base: BaseWidget,
+    callback_id: CallbackId,
+    _click_gesture: GestureClick,
+}
+
+impl VoxTypeWidget {
+    pub fn new(config: VoxTypeConfig) -> Self {
+        let base = BaseWidget::new(&[widget::VOXTYPE]);
+
+        let icon_handle = base.add_icon("audio-input-microphone-symbolic", &[widget::VOXTYPE_ICON]);
+
+        icon_handle.widget().set_visible(config.show_icon);
+
+        base.widget().add_css_class(state::CLICKABLE);
+
+        let click_gesture = GestureClick::new();
+        click_gesture.set_button(gdk::BUTTON_PRIMARY);
+        click_gesture.connect_pressed(move |_gesture, _n_press, _x, _y| {
+            VoxTypeService::global().toggle_recording();
+        });
+        base.content().add_controller(click_gesture.clone());
+
+        let callback_id = {
+            let container = base.widget().clone();
+            let icon_handle = icon_handle.clone();
+
+            VoxTypeService::global().connect(move |snapshot: &VoxTypeSnapshot| {
+                update_widget(&container, &icon_handle, snapshot, config.show_icon);
+            })
+        };
+
+        Self {
+            base,
+            callback_id,
+            _click_gesture: click_gesture,
+        }
+    }
+
+    pub fn widget(&self) -> &gtk4::Box {
+        self.base.widget()
+    }
+}
+
+impl Drop for VoxTypeWidget {
+    fn drop(&mut self) {
+        VoxTypeService::global().disconnect(self.callback_id);
+    }
+}
+
+fn update_widget(
+    container: &gtk4::Box,
+    icon_handle: &crate::services::icons::IconHandle,
+    snapshot: &VoxTypeSnapshot,
+    show_icon: bool,
+) {
+    if !snapshot.available {
+        container.set_visible(false);
+        return;
+    }
+
+    container.set_visible(true);
+
+    icon_handle.remove_css_class(widget::VOXTYPE_RECORDING);
+    icon_handle.remove_css_class(widget::VOXTYPE_TRANSCRIBING);
+
+    match snapshot.state {
+        VoxTypeState::Idle => {
+            icon_handle.set_icon("audio-input-microphone-symbolic");
+        }
+        VoxTypeState::Recording => {
+            icon_handle.add_css_class(widget::VOXTYPE_RECORDING);
+            icon_handle.set_icon("audio-input-microphone-symbolic");
+        }
+        VoxTypeState::Transcribing => {
+            icon_handle.add_css_class(widget::VOXTYPE_TRANSCRIBING);
+            icon_handle.set_icon("audio-input-microphone-symbolic");
+        }
+    }
+
+    icon_handle.widget().set_visible(show_icon);
+
+    let tooltip_text = format!("VoxType: {}", snapshot.state);
+    let tooltip_manager = TooltipManager::global();
+    tooltip_manager.set_styled_tooltip(container, &tooltip_text);
+}
+
+#[cfg(test)]
+mod tests {
+    use super::*;
+    use std::collections::HashMap;
+    use toml::Value;
+
+    fn make_widget_entry(name: &str, options: HashMap<String, Value>) -> WidgetEntry {
+        WidgetEntry {
+            name: name.to_string(),
+            options,
+        }
+    }
+
+    #[test]
+    fn test_voxtype_config_defaults() {
+        let entry = make_widget_entry("voxtype", HashMap::new());
+        let config = VoxTypeConfig::from_entry(&entry);
+        assert!(config.show_icon);
+    }
+
+    #[test]
+    fn test_voxtype_config_show_icon_false() {
+        let mut options = HashMap::new();
+        options.insert("show_icon".to_string(), Value::Boolean(false));
+        let entry = make_widget_entry("voxtype", options);
+        let config = VoxTypeConfig::from_entry(&entry);
+        assert!(!config.show_icon);
+    }
+
+    #[test]
+    fn test_voxtype_state_display() {
+        assert_eq!(VoxTypeState::Idle.to_string(), "Idle");
+        assert_eq!(VoxTypeState::Recording.to_string(), "Recording");
+        assert_eq!(VoxTypeState::Transcribing.to_string(), "Transcribing");
+    }
+}
