+++ b/crates/vibepanel/src/services/voxtype.rs
@@ -0,0 +1,306 @@
+//! VoxTypeService - event-driven VoxType dictation daemon state observer.
+//!
+//! Watches `$XDG_RUNTIME_DIR/voxtype/` via inotify for state changes and
+//! provides click-to-toggle control by sending SIGUSR1/SIGUSR2 to the daemon.
+//!
+//! No polling is used. The inotify watcher fires callbacks only when the
+//! `state` or `pid` files actually change on disk.
+
+use std::cell::RefCell;
+use std::fs;
+use std::path::{Path, PathBuf};
+use std::rc::Rc;
+use std::sync::Arc;
+use std::sync::atomic::{AtomicBool, Ordering};
+use std::thread;
+use std::time::Duration;
+
+use gtk4::glib;
+use notify_debouncer_mini::{DebounceEventResult, new_debouncer, notify::RecursiveMode};
+use tracing::{debug, error, info, warn};
+
+use super::callbacks::{CallbackId, Callbacks};
+
+const FILE_CHANGE_DEBOUNCE_MS: u64 = 100;
+
+/// VoxType daemon state values, matching the state file contents.
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum VoxTypeState {
+    Idle,
+    Recording,
+    Transcribing,
+}
+
+impl std::fmt::Display for VoxTypeState {
+    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
+        match self {
+            VoxTypeState::Idle => write!(f, "Idle"),
+            VoxTypeState::Recording => write!(f, "Recording"),
+            VoxTypeState::Transcribing => write!(f, "Transcribing"),
+        }
+    }
+}
+
+/// Canonical snapshot of VoxType daemon state.
+#[derive(Debug, Clone)]
+pub struct VoxTypeSnapshot {
+    /// Whether the VoxType daemon is running (PID file exists).
+    pub available: bool,
+    /// Current dictation state.
+    pub state: VoxTypeState,
+}
+
+impl VoxTypeSnapshot {
+    pub fn unavailable() -> Self {
+        Self {
+            available: false,
+            state: VoxTypeState::Idle,
+        }
+    }
+}
+
+/// Shared, process-wide VoxType state service.
+///
+/// Uses inotify (via the `notify` crate) to watch the VoxType runtime directory
+/// for file changes. When the `state` or `pid` file changes, the snapshot is
+/// updated and all registered callbacks are notified on the GLib main loop.
+pub struct VoxTypeService {
+    snapshot: RefCell<VoxTypeSnapshot>,
+    callbacks: Callbacks<VoxTypeSnapshot>,
+    #[allow(dead_code)]
+    shutdown_flag: Arc<AtomicBool>,
+}
+
+impl VoxTypeService {
+    fn new() -> Rc<Self> {
+        let runtime_dir = voxtype_runtime_dir();
+
+        let initial_snapshot = match &runtime_dir {
+            Some(dir) => {
+                let pid_exists = dir.join("pid").exists();
+                let state = if pid_exists {
+                    read_state_file(&dir.join("state")).unwrap_or(VoxTypeState::Idle)
+                } else {
+                    VoxTypeState::Idle
+                };
+                VoxTypeSnapshot {
+                    available: pid_exists,
+                    state,
+                }
+            }
+            None => VoxTypeSnapshot::unavailable(),
+        };
+
+        let shutdown_flag = Arc::new(AtomicBool::new(false));
+
+        let service = Rc::new(Self {
+            snapshot: RefCell::new(initial_snapshot),
+            callbacks: Callbacks::new(),
+            shutdown_flag: shutdown_flag.clone(),
+        });
+
+        if let Some(dir) = runtime_dir {
+            Self::start_watcher(&dir, shutdown_flag);
+        } else {
+            warn!("VoxTypeService: XDG_RUNTIME_DIR not set; service disabled");
+        }
+
+        service
+    }
+
+    pub fn global() -> Rc<Self> {
+        thread_local! {
+            static INSTANCE: Rc<VoxTypeService> = VoxTypeService::new();
+        }
+        INSTANCE.with(|s| s.clone())
+    }
+
+    pub fn connect<F>(&self, callback: F) -> CallbackId
+    where
+        F: Fn(&VoxTypeSnapshot) + 'static,
+    {
+        let id = self.callbacks.register(callback);
+        self.callbacks.notify_single(id, &self.snapshot.borrow());
+        id
+    }
+
+    pub fn disconnect(&self, id: CallbackId) -> bool {
+        self.callbacks.unregister(id)
+    }
+
+    #[allow(dead_code)]
+    pub fn snapshot(&self) -> VoxTypeSnapshot {
+        self.snapshot.borrow().clone()
+    }
+
+    /// Toggle recording: sends SIGUSR1 (start) or SIGUSR2 (stop) to the daemon.
+    pub fn toggle_recording(&self) {
+        let dir = match voxtype_runtime_dir() {
+            Some(d) => d,
+            None => {
+                warn!("VoxType: no runtime directory, cannot toggle");
+                return;
+            }
+        };
+
+        let pid = match read_pid_file(&dir.join("pid")) {
+            Some(p) => p,
+            None => {
+                warn!("VoxType: no PID file, daemon not running?");
+                return;
+            }
+        };
+
+        let signal = match self.snapshot.borrow().state {
+            VoxTypeState::Idle => libc::SIGUSR1,
+            VoxTypeState::Recording | VoxTypeState::Transcribing => libc::SIGUSR2,
+        };
+
+        unsafe {
+            if libc::kill(pid, signal) != 0 {
+                let errno = *libc::__errno_location();
+                warn!(
+                    "VoxType: failed to send signal to pid {}: errno {}",
+                    pid, errno
+                );
+            } else {
+                debug!("VoxType: sent signal {} to pid {}", signal, pid);
+            }
+        }
+    }
+
+    fn start_watcher(runtime_dir: &Path, shutdown_flag: Arc<AtomicBool>) {
+        if !runtime_dir.exists()
+            && let Err(e) = fs::create_dir_all(runtime_dir)
+        {
+            warn!(
+                "VoxType: failed to create runtime dir {}: {}",
+                runtime_dir.display(),
+                e
+            );
+            return;
+        }
+
+        let dir = runtime_dir.to_path_buf();
+        thread::spawn(move || {
+            Self::run_watcher(&dir, shutdown_flag);
+        });
+    }
+
+    fn run_watcher(runtime_dir: &Path, shutdown_flag: Arc<AtomicBool>) {
+        let debounce_duration = Duration::from_millis(FILE_CHANGE_DEBOUNCE_MS);
+
+        let dir_for_cb = runtime_dir.to_path_buf();
+        let mut debouncer = match new_debouncer(
+            debounce_duration,
+            move |res: DebounceEventResult| match res {
+                Ok(events) => {
+                    for e in &events {
+                        debug!(
+                            "VoxType watcher event: {:?} path={}",
+                            e.kind,
+                            e.path.display()
+                        );
+                    }
+                    let relevant = events.iter().any(|e| {
+                        e.path
+                            .file_name()
+                            .is_some_and(|n| n == "state" || n == "pid")
+                    });
+                    if relevant {
+                        debug!("VoxType: relevant state/pid change detected");
+                        let dir = dir_for_cb.clone();
+                        glib::idle_add_once(move || {
+                            VoxTypeService::global().update_from_files(&dir);
+                        });
+                    }
+                }
+                Err(err) => {
+                    error!("VoxType file watcher error: {}", err);
+                }
+            },
+        ) {
+            Ok(d) => d,
+            Err(e) => {
+                error!("VoxType: failed to create file watcher: {}", e);
+                return;
+            }
+        };
+
+        if let Err(e) = debouncer
+            .watcher()
+            .watch(runtime_dir, RecursiveMode::NonRecursive)
+        {
+            warn!("VoxType: failed to watch {}: {}", runtime_dir.display(), e);
+            return;
+        }
+
+        info!(
+            "VoxType watcher started, watching: {}",
+            runtime_dir.display()
+        );
+
+        while !shutdown_flag.load(Ordering::Relaxed) {
+            thread::sleep(Duration::from_millis(500));
+        }
+
+        debug!("VoxType file watcher thread shutting down");
+    }
+
+    fn update_from_files(&self, runtime_dir: &Path) {
+        let pid_exists = runtime_dir.join("pid").exists();
+        let new_state = if pid_exists {
+            read_state_file(&runtime_dir.join("state")).unwrap_or(VoxTypeState::Idle)
+        } else {
+            VoxTypeState::Idle
+        };
+
+        debug!(
+            "VoxType update_from_files: available={}, state={}",
+            pid_exists, new_state
+        );
+
+        let new_snapshot = VoxTypeSnapshot {
+            available: pid_exists,
+            state: new_state,
+        };
+
+        let mut snapshot = self.snapshot.borrow_mut();
+        if snapshot.available == new_snapshot.available && snapshot.state == new_snapshot.state {
+            debug!("VoxType: no state change, skipping notification");
+            return;
+        }
+        info!(
+            "VoxType state changed: {:?} -> {:?}",
+            (snapshot.available, snapshot.state),
+            (new_snapshot.available, new_snapshot.state)
+        );
+        *snapshot = new_snapshot;
+        drop(snapshot);
+        self.callbacks.notify(&self.snapshot.borrow());
+    }
+}
+
+fn voxtype_runtime_dir() -> Option<PathBuf> {
+    std::env::var("XDG_RUNTIME_DIR")
+        .ok()
+        .map(|d| PathBuf::from(d).join("voxtype"))
+}
+
+fn read_state_file(path: &Path) -> Option<VoxTypeState> {
+    let content = fs::read_to_string(path).ok()?;
+    match content.trim() {
+        "idle" => Some(VoxTypeState::Idle),
+        "recording" => Some(VoxTypeState::Recording),
+        "transcribing" => Some(VoxTypeState::Transcribing),
+        other => {
+            debug!("VoxType: unknown state '{}', treating as idle", other);
+            Some(VoxTypeState::Idle)
+        }
+    }
+}
+
+fn read_pid_file(path: &Path) -> Option<libc::pid_t> {
+    let content = fs::read_to_string(path).ok()?;
+    content.trim().parse().ok()
+}
